# Resend API Configuration
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Email Configuration
# Where to send contact form submissions and survey data
CONTACT_EMAIL=contact@pimlicosolutions.com

# Articles API Key — required for external agents to publish/update/delete articles
# Generate a strong random key and set it in Vercel Environment Variables
ARTICLES_API_KEY=your_articles_api_key_here

# Note: You'll also need to verify your domain in Resend
# to send from @pimlicosolutions.com addresses
# See: https://resend.com/domains
