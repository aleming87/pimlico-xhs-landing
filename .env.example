# ─────────────────────────────────────────────────────────────
# Resend (transactional email)
# ─────────────────────────────────────────────────────────────
# API key from https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Sender address — must use a verified domain in Resend.
# Defaults to noreply@pimlicosolutions.com if unset.
SENDER_EMAIL=noreply@pimlicosolutions.com

# Recipient for inbound contact form / survey notifications
CONTACT_EMAIL=contact@pimlicosolutions.com

# Resend webhook signing secret (Resend dashboard → Webhooks → endpoint).
# Used to verify incoming webhooks at /api/webhooks/resend.
# Format: whsec_...
RESEND_WEBHOOK_SECRET=whsec_your_secret_here

# ─────────────────────────────────────────────────────────────
# Google Analytics 4
# ─────────────────────────────────────────────────────────────
# GA4 Measurement ID — required for client-side gtag to load.
# Format: G-XXXXXXXXXX. Without this, no analytics fire.
NEXT_PUBLIC_GA_ID=

# Measurement Protocol API secret — for server-side events (Resend
# webhook → GA4). GA4 Admin → Data Streams → Measurement Protocol.
GA_MEASUREMENT_API_SECRET=

# ─────────────────────────────────────────────────────────────
# Search Console / Bing Webmaster
# ─────────────────────────────────────────────────────────────
# Verification tokens — extract just the `content="..."` value from
# the meta tag each console gives you. Renders into <head>.
NEXT_PUBLIC_GSC_VERIFICATION=
NEXT_PUBLIC_BING_VERIFICATION=

# ─────────────────────────────────────────────────────────────
# Articles API
# ─────────────────────────────────────────────────────────────
# Required for external agents to publish/update/delete articles
ARTICLES_API_KEY=your_articles_api_key_here
